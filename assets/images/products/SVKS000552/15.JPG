		<!-- Animate Big Circle Link -->
		<script>
			var myElement = document.querySelector('.circle-link');
			var bounding = myElement.getBoundingClientRect();
			var myElementHeight = myElement.offsetHeight;
			var myElementWidth = myElement.offsetWidth;

			var stampListener = window.addEventListener('scroll', _.throttle(elementInViewport, 160));

			function elementInViewport() {
				var bounding = myElement.getBoundingClientRect();
				if (bounding.top >= -myElementHeight 
					&& bounding.left >= -myElementWidth
					&& bounding.right <= (window.innerWidth || document.documentElement.clientWidth) + myElementWidth
					&& bounding.bottom <= (window.innerHeight || document.documentElement.clientHeight) + myElementHeight) {

					myElement.classList.add("animate");
				//	window.removeEventListener('scroll', _.throttle(elementInViewport, 160));
				} else {
				//	myElement.classList.remove("animate");
				}
			}
		</script>

